#############  STEP 6: TRAINING COPIES & TRANSFORMATIONS  ############## 
#----------- Copy 1: WITH Collinearity cutoff (0.85), then Box-Cox + Spatial Sign ----# 
X_train_c1 <- X_train_full 
# Correlation & collinearity cutoff on training only 
cor_train_c1 <- cor(X_train_c1, use = "pairwise.complete.obs") 
high_corr_idx_c1   <- findCorrelation(cor_train_c1, cutoff = 0.85) 
high_corr_names_c1 <- colnames(X_train_c1)[high_corr_idx_c1] 
cat("Copy 1 - Predictors removed due to correlation > 0.85:\n") 
print(high_corr_names_c1) 
# Remove from training 
if (length(high_corr_idx_c1) > 0) { 
X_train_c1 <- X_train_c1[, -high_corr_idx_c1, drop = FALSE] 
} 
# Box-Cox + center + scale on training (Copy 1) 
preprocess_c1 <- preProcess( 
X_train_c1, 
method = c("BoxCox", "center", "scale") 
) 
X_train_c1_bc <- predict(preprocess_c1, X_train_c1) 
# Spatial Sign (Copy 1) 
X_train_c1_final <- spatialSign(X_train_c1_bc) 
# Prepare corresponding test predictors for Copy 1 
X_test_c1 <- X_test_full[, colnames(X_train_c1), drop = FALSE] 
X_test_c1_bc <- predict(preprocess_c1, X_test_c1) 
X_test_c1_final <- spatialSign(X_test_c1_bc) 
#----------- Copy 2: NO Collinearity cutoff; Box-Cox + Spatial Sign ----# 
X_train_c2 <- X_train_full 
preprocess_c2 <- preProcess( 
X_train_c2, 
method = c("BoxCox", "center", "scale") 
) 
X_train_c2_bc <- predict(preprocess_c2, X_train_c2) 
X_train_c2_final <- spatialSign(X_train_c2_bc) 
# Test set for Copy 2 
