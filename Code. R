## 2. Neural Network (avNNet) 
nnet_grid <- expand.grid( 
.size  = c(3, 5, 7, 9), 
.decay = c(0.001, 0.01, 0.1), 
.bag   = FALSE 
) 
set.seed(1) 
fit_nnet <- train( 
x = X_train_c1_final, 
y = y_train_scaled, 
preProcess = c("center", "scale","spatialSign"), 
method  = "avNNet", 
tuneGrid = nnet_grid, 
linout   = TRUE, 
trace    = FALSE, 
maxit    = 500, 
trControl = ctrl 
) 
## 3. MARS (earth) 
mars_grid <- expand.grid( 
.degree = 1:2, 
.nprune = 2:50 
) 
set.seed(1) 
