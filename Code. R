y_train_scaled_df <- predict(pp_y, data.frame(y = y_train)) 
y_train_scaled    <- y_train_scaled_df$y 
# Helper to invert scaling on predictions 
inv_scale_y <- function(y_scaled, pp_obj) { 
mu  <- pp_obj$mean["y"] 
sig <- pp_obj$std["y"] 
return(y_scaled * sig + mu) 
} 
# TrainControl 
ctrl <- trainControl( 
method = "cv", 
number = 10, 
verboseIter = TRUE, 
savePredictions = "final" 
) 
