, sapply(predictors_mv, function(x) is.factor(x) || is.character(x)), 
drop = FALSE 
] 
num_vars <- predictors_mv[ 
, sapply(predictors_mv, is.numeric), 
drop = FALSE 
] 
# Remove ID-like columns from categoricals 
id_like <- c("run_id", "run_id.1", "node") 
cat_vars <- cat_vars[ 
, !(names(cat_vars) %in% id_like), 
drop = FALSE 
] 
# Ensure all categorical vars are factors 
for (c in names(cat_vars)) { 
cat_vars[[c]] <- as.factor(cat_vars[[c]]) 
} 
# Remove single-level factors 
cat_vars <- cat_vars[ 
, sapply(cat_vars, function(x) nlevels(x) > 1), 
drop = FALSE 
] 
# Dummy Encoding 
if (ncol(cat_vars) > 0) { 
dummy_model <- dummyVars(" ~ .", data = cat_vars, fullRank = TRUE) 
dummy_data  <- as.data.frame(predict(dummy_model, newdata = cat_vars)) 
} else { 
dummy_data <- NULL 
} 
# Combine numeric + dummy predictors 
if (!is.null(dummy_data)) { 
predictors_encoded <- cbind(num_vars, dummy_data) 
} else { 
predictors_encoded <- num_vars 
} 
final_dataset <- data.frame(predictors_encoded, energy = response_mv) 
cat("Dummy encoding completed. Total predictors now:", ncol(predictors_encoded), "\n") 
