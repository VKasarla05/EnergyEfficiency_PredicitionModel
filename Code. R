evaluate_model_scaled <- function(model_name, model_object) { 
perf <- getTrainPerf(model_object) 
cat("\nModel:", model_name, "(on SCALED target)\n") 
cat("RMSE (scaled):", round(perf$TrainRMSE, 4), "\n") 
cat("R-sq  (scaled):", round(perf$TrainRsquared, 4), "\n") 
cat("MAE  (scaled):", round(perf$TrainMAE, 4), "\n") 
} 
